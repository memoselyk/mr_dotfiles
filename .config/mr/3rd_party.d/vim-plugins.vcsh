# Version control (git) integration
[.vim/bundle/fugitive]
checkout =
   git clone --separate-git-dir ~/.config/vcsh/repo.d/vim-fugitive.git https://github.com/tpope/vim-fugitive.git ~/.vim/bundle/fugitive
push = :
order = 15

# Fuzzy search of files
[.vim/bundle/ctrlp.vim]
checkout =
   git clone --separate-git-dir ~/.config/vcsh/repo.d/vim-ctrlp.git https://github.com/ctrlpvim/ctrlp.vim ~/.vim/bundle/ctrlp.vim
push = :
order = 15
